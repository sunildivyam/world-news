{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Next.js: dev",
      "type": "node",
      "request": "launch",
      "args": ["dev"],
      "cwd": "${workspaceFolder}/apps/web",
      "runtimeExecutable": "pnpm",
      "console": "integratedTerminal",
      "timeout": 300000,
      "env": {
        "NODE_OPTIONS": "--inspect=9229"
      },
      "skipFiles": ["<node_internals>/**", "node_modules/**"]
    },
    {
      "name": "Next.js: attach",
      "type": "node",
      "request": "attach",
      "port": 9229,
      "restart": true,
      "localRoot": "${workspaceFolder}/apps/web",
      "remoteRoot": "${workspaceFolder}/apps/web",
      "skipFiles": ["<node_internals>/**", "node_modules/**"]
    }
  ]
}
